{
  "name": "joelburigo-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ulimit -n 65536 && next dev -p 4321",
    "dev:tunnel": "ulimit -n 65536 && concurrently -n DEV,TUN -c cyan,magenta --kill-others-on-fail \"pnpm dev\" \"pnpm tunnel\"",
    "build": "next build",
    "start": "next start -p 4321",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare preview --env dev",
    "cf:deploy:dev": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env dev",
    "cf:deploy:prod": "opennextjs-cloudflare build && opennextjs-cloudflare deploy --env prod",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx --conditions=react-server src/server/db/seed.ts",
    "db:migrate-blog": "tsx --conditions=react-server scripts/migrate-blog.ts",
    "tunnel": "test -f .cloudflared.token || (echo 'Falta .cloudflared.token (gitignored). Cole o token do tunnel joelburigo-dev.'; exit 1) && cloudflared tunnel run --token \"$(cat .cloudflared.token)\"",
    "optimize:images": "node scripts/optimize-images.mjs",
    "audio:generate": "node scripts/generate-audio-posts.mjs",
    "audio:post": "node scripts/generate-audio-posts.mjs --post"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@googleapis/calendar": "^14.2.0",
    "@googleapis/oauth2": "^5.0.1",
    "@opennextjs/cloudflare": "^1.19.4",
    "@radix-ui/react-avatar": "^1.1.2",
    "@radix-ui/react-checkbox": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.3",
    "@radix-ui/react-dropdown-menu": "^2.1.3",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-popover": "^1.1.3",
    "@radix-ui/react-progress": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.3",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.1.2",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-toast": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.1.5",
    "@tailwindcss/postcss": "^4.2.3",
    "@tiptap/extension-link": "^2.10.3",
    "@tiptap/extension-placeholder": "^2.10.3",
    "@tiptap/pm": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@tiptap/starter-kit": "^2.10.3",
    "agentation": "^3.0.2",
    "ai": "^6.0.168",
    "chart.js": "^4.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.0",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "drizzle-orm": "^0.45.2",
    "google-auth-library": "^10.6.2",
    "gray-matter": "^4.0.3",
    "jose": "^6.2.2",
    "lucide-react": "^1.11.0",
    "mercadopago": "^2.5.0",
    "next": "^16.2.4",
    "next-themes": "^0.4.4",
    "openai": "^6.34.0",
    "postgres": "^3.4.9",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "server-only": "^0.0.1",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.3",
    "tailwindcss-animate": "^1.0.7",
    "tiptap-markdown": "^0.8.10",
    "ulid": "^3.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.4",
    "path-to-regexp": "^8.4.2",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "wrangler": "^4.86.0"
  },
  "overrides": {
    "path-to-regexp": "^8.4.2",
    "yaml": "^2.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "pnpm@10.0.0"
}
